# Questo file dovrà essere rinominato in ".env"

# URI del database Neo4j
# Esempio locale:
# NEO4J_URI=bolt://localhost:7687
#
# Esempio server:
# NEO4J_URI=bolt://neo4j.example.com:7687
NEO4J_URI=

# Nome utente Neo4j
NEO4J_USER=

# Password dell'utente Neo4j
NEO4J_PASSWORD=

# Nome del database Neo4j
# Default Neo4j 5: neo4j
NEO4J_DATABASE=

# Porta su cui verrà eseguito il backend Node.js
# Default: 3001
PORT=3001